---
import '../styles/global.css';

interface Props {
	title: string;
	lang: 'de' | 'en';
	backHref: string;
	backLabel: string;
}

const { title, lang, backHref, backLabel } = Astro.props;
---

<html lang={lang}>
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>{title} – ExploreMath</title>
		<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css" />
	</head>
	<body class="bg-slate-50 text-slate-900 min-h-screen">
		<header class="bg-white border-b border-slate-200">
			<nav class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
				<a href="/explore-math/" class="text-2xl font-bold text-indigo-600">ExploreMath</a>
				<div class="flex gap-4 text-sm">
					<a href={backHref} class="hover:text-indigo-600">{backLabel}</a>
				</div>
			</nav>
		</header>
		<main class="max-w-4xl mx-auto px-6 py-12">
			<slot />
		</main>
	</body>
</html>
