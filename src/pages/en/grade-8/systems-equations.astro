---
import Layout from '../../../layouts/Layout.astro';
import FunctionPlotter from '../../../components/diagrams/FunctionPlotter.svelte';
---

<Layout title="Systems of Equations" lang="en" backHref="/explore-math/en/grade-8/" backLabel="← Grade 8">
	<h1 class="text-3xl font-bold mb-2">Systems of Equations</h1>
	<p class="text-lg text-slate-600 mb-8">Two equations, two unknowns — three solution methods</p>

	<section class="prose max-w-none">
		<h2>Where do two lines meet?</h2>
		<p>A system of linear equations consists of two equations. The solution is the point where both lines intersect.</p>

		<h3>🧪 Experiment: Finding the Intersection</h3>
		<p>Here you see y = a·x + 1. Change the slope and observe:</p>
	</section>

	<FunctionPlotter client:visible fn={(x, a) => a * x + 1} fnLabel="y = a·x + 1" showSlider={true} sliderLabel="a" sliderMin={-2} sliderMax={2} />

	<section class="prose max-w-none mt-8">
		<h3>💡 Three Solution Methods</h3>
		<ul>
			<li><strong>Substitution:</strong> Isolate one variable and plug into the other equation</li>
			<li><strong>Elimination:</strong> Add equations so one variable cancels out</li>
			<li><strong>Graphical:</strong> Plot both lines and find where they cross</li>
		</ul>
	</section>
</Layout>
