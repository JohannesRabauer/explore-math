---
import Layout from '../../../layouts/Layout.astro';
import FunctionPlotter from '../../../components/diagrams/FunctionPlotter.svelte';
---

<Layout title="Quadratic Equations" lang="en" backHref="/explore-math/en/grade-9/" backLabel="← Grade 9">
	<h1 class="text-3xl font-bold mb-2">Quadratic Equations</h1>
	<p class="text-lg text-slate-600 mb-8">The quadratic formula and solution methods</p>
	<section class="prose max-w-none">
		<h2>Finding Zeros</h2>
		<p>ax² + bx + c = 0 — where does the parabola cross the x-axis?</p>
		<h3>🧪 Experiment</h3>
		<p>Change the parameter and observe the zeros:</p>
	</section>
	<FunctionPlotter client:visible fn={(x, a) => x*x + a*x - 2} fnLabel="y = x² + a·x − 2" showSlider={true} sliderLabel="a" sliderMin={-3} sliderMax={3} yMin={-5} yMax={5} />
	<section class="prose max-w-none mt-8">
		<h3>💡 Quadratic Formula</h3>
		<p>x = (−b ± √(b²−4ac)) / 2a</p>
		<ul>
			<li>Discriminant > 0: two solutions</li>
			<li>Discriminant = 0: one solution (tangent point)</li>
			<li>Discriminant < 0: no real solution</li>
		</ul>
	</section>
</Layout>
