---
import Layout from '../../../layouts/Layout.astro';
import FunctionPlotter from '../../../components/diagrams/FunctionPlotter.svelte';
---

<Layout title="Integral Calculus" lang="en" backHref="/explore-math/en/grade-12/" backLabel="← Grade 12">
	<h1 class="text-3xl font-bold mb-2">Integral Calculus</h1>
	<p class="text-lg text-slate-600 mb-8">Calculate areas under curves</p>
	<section class="prose max-w-none">
		<h2>The Integral</h2>
		<p>Integration reverses differentiation and calculates areas under curves.</p>
		<h3>🧪 Experiment</h3>
		<p>Area under f(x) = a·x:</p>
	</section>
	<FunctionPlotter client:visible fnExpr="a * x" fnLabel="f(x) = a·x" showSlider={true} sliderLabel="a" sliderMin={0.5} sliderMax={2} sliderStep={0.25} />
	<section class="prose max-w-none mt-8">
		<h3>💡 Basics</h3>
		<ul><li>∫xⁿ dx = xⁿ⁺¹/(n+1) + C</li><li>∫eˣ dx = eˣ + C</li><li>∫sin(x) dx = −cos(x) + C</li><li>Definite integral: F(b) − F(a)</li></ul>
	</section>
</Layout>
