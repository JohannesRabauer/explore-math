---
import '../../../styles/global.css';
import { lessons } from '../../../data/lessons';

export function getStaticPaths() {
  return [5,6,7,8,9,10,11,12].map(n => ({
    params: { grade: `grade-${n}` },
    props: { num: n, items: lessons[n] },
  }));
}
const { num, items } = Astro.props;
---

<html lang="en">
<head><meta charset="utf-8" /><meta name="viewport" content="width=device-width, initial-scale=1" /><title>Grade {num} – ExploreMath</title></head>
<body class="bg-slate-50 text-slate-900 min-h-screen">
<header class="bg-white border-b border-slate-200"><nav class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between"><a href="/explore-math/" class="text-2xl font-bold text-indigo-600">ExploreMath</a><div class="flex gap-4 text-sm"><a href="/explore-math/en/" class="hover:text-indigo-600">← All Grades</a><a href="/explore-math/de/" class="hover:text-indigo-600">Deutsch</a></div></nav></header>
<main class="max-w-4xl mx-auto px-6 py-12">
<h1 class="text-4xl font-bold mb-2">Grade {num}</h1>
<p class="text-slate-600 mb-10">Choose a lesson and discover mathematics through experiments.</p>
<div class="space-y-4">
{items.map((lesson, i) => (
<a href={`/explore-math/en/grade-${num}/${lesson.slugEn}/`} class="block bg-white rounded-xl p-6 shadow-sm border border-slate-200 hover:border-indigo-400 hover:shadow-md transition-all"><div class="flex items-start gap-4"><div class="w-10 h-10 rounded-lg bg-indigo-100 text-indigo-600 flex items-center justify-center font-bold shrink-0">{i+1}</div><div><h2 class="text-lg font-semibold">{lesson.titleEn}</h2><p class="text-slate-600 text-sm mt-1">{lesson.descEn}</p></div></div></a>
))}
</div>
</main></body></html>
