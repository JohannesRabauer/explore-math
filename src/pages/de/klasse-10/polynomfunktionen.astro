---
import Layout from '../../../layouts/Layout.astro';
import FunctionPlotter from '../../../components/diagrams/FunctionPlotter.svelte';
---

<Layout title="Polynomfunktionen" lang="de" backHref="/explore-math/de/klasse-10/" backLabel="← Klasse 10">
	<h1 class="text-3xl font-bold mb-2">Polynomfunktionen</h1>
	<p class="text-lg text-slate-600 mb-8">Ganzrationale Funktionen und ihre Eigenschaften</p>
	<section class="prose max-w-none">
		<h2>Höhere Potenzen</h2>
		<p>Polynome sind Summen von Potenzfunktionen. Je höher der Grad, desto mehr Wendepunkte.</p>
		<h3>🧪 Experiment</h3>
		<p>Kubische Funktion mit Parameter:</p>
	</section>
	<FunctionPlotter client:visible fnExpr="x*x*x - a*x" fnLabel="y = x³ − a·x" showSlider={true} sliderLabel="a" sliderMin={0} sliderMax={4} sliderStep={0.5} yMin={-5} yMax={5} />
	<section class="prose max-w-none mt-8">
		<h3>💡 Eigenschaften</h3>
		<ul><li>Grad n → maximal n Nullstellen</li><li>Gerade Exponenten: y-Achsen-symmetrisch</li><li>Ungerade Exponenten: punktsymmetrisch</li></ul>
	</section>
</Layout>
