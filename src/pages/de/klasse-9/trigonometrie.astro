---
import Layout from '../../../layouts/Layout.astro';
import FunctionPlotter from '../../../components/diagrams/FunctionPlotter.svelte';
---

<Layout title="Trigonometrie Grundlagen" lang="de" backHref="/explore-math/de/klasse-9/" backLabel="← Klasse 9">
	<h1 class="text-3xl font-bold mb-2">Trigonometrie Grundlagen</h1>
	<p class="text-lg text-slate-600 mb-8">Sinus, Kosinus und Tangens im rechtwinkligen Dreieck</p>
	<section class="prose max-w-none">
		<h2>Die Winkelfunktionen</h2>
		<p>sin(α) = Gegenkathete/Hypotenuse, cos(α) = Ankathete/Hypotenuse, tan(α) = Gegenkathete/Ankathete</p>
		<h3>🧪 Experiment: Sinus und Kosinus</h3>
		<p>Hier siehst du sin(x) — eine Wellenbewegung! Verändere die Amplitude:</p>
	</section>
	<FunctionPlotter client:visible fn={(x, a) => a * Math.sin(x)} fnLabel="y = a·sin(x)" showSlider={true} sliderLabel="a" sliderMin={0.5} sliderMax={3} sliderStep={0.25} xMin={-7} xMax={7} />
	<section class="prose max-w-none mt-8">
		<h3>💡 Merkhilfe: SOH-CAH-TOA</h3>
		<ul>
			<li><strong>S</strong>in = <strong>O</strong>pposite / <strong>H</strong>ypotenuse</li>
			<li><strong>C</strong>os = <strong>A</strong>djacent / <strong>H</strong>ypotenuse</li>
			<li><strong>T</strong>an = <strong>O</strong>pposite / <strong>A</strong>djacent</li>
		</ul>
	</section>
</Layout>
