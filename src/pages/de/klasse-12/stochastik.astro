---
import Layout from '../../../layouts/Layout.astro';
import FunctionPlotter from '../../../components/diagrams/FunctionPlotter.svelte';
---

<Layout title="Stochastik" lang="de" backHref="/explore-math/de/klasse-12/" backLabel="← Klasse 12">
	<h1 class="text-3xl font-bold mb-2">Stochastik</h1>
	<p class="text-lg text-slate-600 mb-8">Binomialverteilung und Hypothesentests</p>
	<section class="prose max-w-none">
		<h2>Binomialverteilung</h2>
		<p>Wie oft fällt Kopf bei 10 Würfen? Die Binomialverteilung gibt die Antwort.</p>
		<h3>🧪 Experiment</h3>
		<p>Normalverteilung als Approximation:</p>
	</section>
	<FunctionPlotter client:visible fnExpr="Math.exp(-x*x/(2*s*s)) / (s*Math.sqrt(2*Math.PI))" fnLabel="Normalverteilung" showSlider={true} sliderLabel="σ" sliderMin={0.5} sliderMax={2} sliderStep={0.1} xMin={-5} xMax={5} yMin={0} yMax={1} />
	<section class="prose max-w-none mt-8">
		<h3>💡 Hypothesentests</h3>
		<ul><li>H₀: Nullhypothese</li><li>H₁: Alternativhypothese</li><li>Signifikanzniveau α (meist 5%)</li><li>Verwerfungsbereich bestimmen</li></ul>
	</section>
</Layout>
