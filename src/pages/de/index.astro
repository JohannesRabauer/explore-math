---
import '../../styles/global.css';

const grades = [
	{ num: 5, topics: ['Natürliche Zahlen', 'Grundlagen der Geometrie', 'Einführung Brüche'] },
	{ num: 6, topics: ['Bruchrechnung', 'Dezimalzahlen', 'Winkel'] },
	{ num: 7, topics: ['Ganze Zahlen', 'Lineare Gleichungen', 'Dreiecke'] },
	{ num: 8, topics: ['Lineare Funktionen', 'Satz des Pythagoras', 'Wahrscheinlichkeit'] },
	{ num: 9, topics: ['Quadratische Funktionen', 'Potenzen', 'Trigonometrie'] },
	{ num: 10, topics: ['Exponentialfunktionen', 'Kreise', 'Statistik'] },
	{ num: 11, topics: ['Differentialrechnung', 'Vektoren', 'Funktionsanalyse'] },
	{ num: 12, topics: ['Integralrechnung', 'Stochastik', 'Analytische Geometrie'] },
];
---

<html lang="de">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>Klassenstufen – ExploreMath</title>
	</head>
	<body class="bg-slate-50 text-slate-900 min-h-screen">
		<header class="bg-white border-b border-slate-200">
			<nav class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
				<a href="/explore-math/" class="text-2xl font-bold text-indigo-600">ExploreMath</a>
				<div class="flex gap-4 text-sm">
					<span class="text-indigo-600 font-medium">Deutsch</span>
					<a href="/explore-math/en/" class="hover:text-indigo-600">English</a>
				</div>
			</nav>
		</header>

		<main class="max-w-6xl mx-auto px-6 py-12">
			<h1 class="text-4xl font-bold mb-2">Klassenstufen</h1>
			<p class="text-slate-600 mb-10">Wähle deine Klassenstufe und entdecke Mathematik durch Experimente.</p>

			<div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
				{grades.map((g) => (
					<div class="bg-white rounded-xl p-5 shadow-sm border border-slate-200 hover:border-indigo-300 transition-colors">
						<div class="text-3xl font-bold text-indigo-600 mb-2">Klasse {g.num}</div>
						<ul class="text-sm text-slate-600 space-y-1">
							{g.topics.map((t) => <li>• {t}</li>)}
						</ul>
					</div>
				))}
			</div>
		</main>
	</body>
</html>
